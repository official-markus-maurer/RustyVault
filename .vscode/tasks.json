{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "cargo build",
            "type": "cargo",
            "command": "build",
            "args": [
                "--package",
                "romvault_ui"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$rustc"
            ],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            }
        },
        {
            "label": "cargo run",
            "type": "cargo",
            "command": "run",
            "args": [
                "--package",
                "romvault_ui"
            ],
            "group": "test",
            "problemMatcher": [
                "$rustc"
            ]
        }
    ]
}